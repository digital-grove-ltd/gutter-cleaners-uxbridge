---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services" },
  { label: "Locations", href: "/locations/" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];
---

<!-- Trust signal strip -->
<div class="bg-brand-dark text-white text-xs sm:text-sm py-2 px-4 text-center">
  <span class="inline-flex flex-wrap justify-center gap-x-4 gap-y-1">
    <span>⭐ 5-Star Rated</span>
    <span class="hidden sm:inline text-blue-300">|</span>
    <span>✅ Fully Insured</span>
    <span class="hidden sm:inline text-blue-300">|</span>
    <span>📞 Call Us Today: <a href="tel:+441895000000" class="font-semibold underline hover:text-blue-200 transition-colors">01895 000 000</a></span>
  </span>
</div>

<!-- Main header -->
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border shadow-soft" id="site-header">
  <div class="container-site">
    <div class="flex items-center justify-between h-16 lg:h-18">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Gutter Cleaners Uxbridge - Home">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand to-brand-dark flex items-center justify-center shadow-sm group-hover:shadow-md transition-shadow">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <div class="leading-tight">
          <span class="font-display font-800 text-brand text-base sm:text-lg leading-none block">Gutter Cleaners</span>
          <span class="font-display font-600 text-text-muted text-xs leading-none block">Uxbridge</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-4 py-2 text-sm font-medium text-text-muted rounded-lg hover:text-brand hover:bg-brand-muted transition-all duration-150"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <a href="/#quote" class="btn-primary text-sm py-2.5 px-5">
          Get a Free Quote
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-text-muted hover:text-brand hover:bg-brand-muted transition-all"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-border bg-white"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <nav class="container-site py-4 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-4 py-3 text-sm font-medium text-text-muted rounded-lg hover:text-brand hover:bg-brand-muted transition-all"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3 border-t border-border mt-2">
        <a href="/#quote" class="btn-primary w-full justify-center text-sm py-3">
          Get a Free Quote →
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      menu?.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    } else {
      menu?.classList.remove('hidden');
      hamburger?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
    }
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
