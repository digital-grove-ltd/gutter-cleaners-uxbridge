---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="card-service group flex flex-col gap-4 no-underline" aria-label={`Learn more about ${title}`}>
  <!-- Icon slot -->
  <div class="w-12 h-12 rounded-xl bg-brand-muted flex items-center justify-center text-brand group-hover:bg-brand group-hover:text-white transition-colors duration-300">
    {icon ? (
      <span class="text-xl" aria-hidden="true">{icon}</span>
    ) : (
      <slot name="icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </slot>
    )}
  </div>

  <div class="flex-1">
    <h3 class="font-display font-700 text-text text-lg mb-2 group-hover:text-brand transition-colors">{title}</h3>
    <p class="text-text-muted text-sm leading-relaxed">{description}</p>
  </div>

  <div class="flex items-center gap-1.5 text-brand text-sm font-semibold group-hover:gap-2.5 transition-all">
    Learn more
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</a>
