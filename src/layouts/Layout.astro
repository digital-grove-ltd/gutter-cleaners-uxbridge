---
import "../index.css";
import { Schema } from "astro-seo-schema";
import type { Thing, WithContext } from "schema-dts";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props {
	title?: string;
	description?: string;
	metaDescription?: string;
	canonical?: string;
	noindex?: boolean;
	socialImageUrl?: string;
	schema?: WithContext<Thing> | WithContext<Thing>[];
}

const SITE_NAME = "Gutter Cleaners Uxbridge";
const SITE_DESCRIPTION =
	"Professional gutter cleaning, repair & replacement across Uxbridge, Harrow, Hayes and West London. Free quotes, 5-star rated.";

const { url } = Astro;
const {
	title: pageTitle,
	description = SITE_DESCRIPTION,
	noindex = false,
	socialImageUrl,
	schema,
} = Astro.props;

const title = pageTitle ? `${pageTitle} | ${SITE_NAME}` : SITE_NAME;

const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={url.href} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    {socialImageUrl && (
      <meta property="og:image" content={socialImageUrl} />
      <meta property="og:image:alt" content={title} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}

    <!-- JSON-LD Schema -->
    {schema && (Array.isArray(schema)
      ? schema.map((s) => <Schema item={s} />)
      : <Schema item={schema} />
    )}

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1X2TX059N6" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1X2TX059N6');
    </script>
  </head>

  <body class="min-h-screen bg-surface text-text flex flex-col">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    {isDev && (
      <script is:inline>
        (function() {
          if (window.parent === window) return;
          function sendPageInfo() {
            const title = document.title || '';
            const metaDesc = document.querySelector('meta[name="description"]')?.getAttribute('content') || '';
            const url = window.location.href;
            if (import.meta.env.DEV) { window.parent.postMessage({ type: 'hakuto:page-info', title, description: metaDesc, url }, '*'); }
          }
          sendPageInfo();
          const titleObserver = new MutationObserver(() => sendPageInfo());
          titleObserver.observe(document.querySelector('title') || document.head, { childList: true, subtree: true });
          window.addEventListener('popstate', sendPageInfo);
        })();
      </script>
    )}
  </body>
</html>
