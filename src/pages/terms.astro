---
import Layout from '@/layouts/Layout.astro';

const title = "Terms of Service";
const metaDescription = "Terms of service for Gutter Cleaners Uxbridge — the terms and conditions that apply when you use our website or book our services.";
const canonical = "https://www.guttercleanersuxbridge.co.uk/terms/";
---

<Layout title={title} description={metaDescription} canonical={canonical}>
  <section class="bg-gradient-to-b from-blue-900 to-blue-800 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">Terms of Service</h1>
      <p class="text-lg text-blue-100">Last updated: 1 July 2026</p>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-slate">
      <p>
        These terms govern your use of the Gutter Cleaners Uxbridge website and the services we provide.
        By using our website or booking a service with us, you agree to these terms.
      </p>

      <h2>Our Services</h2>
      <p>
        We provide gutter cleaning, gutter repairs, gutter replacement, and fascia &amp; soffit cleaning
        across Uxbridge, Harrow, Hayes, Hillingdon, Slough, Southall, West Drayton, Windsor and surrounding
        areas of West London. All quotes provided are estimates based on the information you give us and
        may be revised following an on-site survey.
      </p>

      <h2>Quotes &amp; Bookings</h2>
      <ul>
        <li>Quotes requested through our website are free and non-obligatory.</li>
        <li>Final pricing is confirmed after we've assessed the property, either remotely or in person.</li>
        <li>We aim to respond to quote requests within 2 hours during business hours (Mon–Fri, 8am–6pm).</li>
        <li>Appointments are subject to availability and weather conditions where relevant to safe working.</li>
      </ul>

      <h2>Cancellations</h2>
      <p>
        If you need to cancel or reschedule a booked appointment, please let us know as soon as possible.
        We ask for at least 24 hours' notice where practical.
      </p>

      <h2>Liability</h2>
      <p>
        We carry full public liability insurance for all work carried out. While we take every precaution
        to work safely and protect your property, we are not liable for pre-existing damage or wear
        identified during the course of our work, which we will always bring to your attention.
      </p>

      <h2>Payment</h2>
      <p>
        Payment terms will be confirmed at the time of booking or on completion of work, as agreed with
        you directly.
      </p>

      <h2>Website Use</h2>
      <p>
        The content on this website is provided for general information about our services. We make
        reasonable efforts to keep it accurate and up to date, but we do not guarantee that it is free of
        errors or omissions.
      </p>

      <h2>Changes to These Terms</h2>
      <p>
        We may update these terms from time to time. Continued use of our website or services after
        changes are posted constitutes acceptance of the updated terms.
      </p>

      <h2>Contact Us</h2>
      <p>
        If you have any questions about these terms, please <a href="/contact/">get in touch</a>.
      </p>
    </div>
  </section>
</Layout>
