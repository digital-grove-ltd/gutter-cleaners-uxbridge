---
import Layout from '@/layouts/Layout.astro';
import QuoteForm from '@/components/QuoteForm';
import TrustBar from '@/components/TrustBar.astro';
import { breadcrumbSchema, localBusinessWithAreaSchema, faqSchema, serviceSchema } from '@/lib/schema';
import type { WithContext, Thing } from 'schema-dts';
import { MapPin, ArrowRight } from 'lucide-react';

const title = "Gutter Repairs Hillingdon UB10 | Same-Week Response";
const metaDescription = "Fast gutter repairs in Hillingdon UB10. Leaking joints, sagging gutters, cracked sections. Specialists in mixed 1930s to 1960s housing.";

const breadcrumbItems = [
  { name: "Home", url: "https://www.guttercleanersuxbridge.co.uk/" },
  { name: "Locations", url: "https://www.guttercleanersuxbridge.co.uk/locations/" },
  { name: "Hillingdon", url: "https://www.guttercleanersuxbridge.co.uk/locations/hillingdon/" },
  { name: "Gutter Repairs", url: "https://www.guttercleanersuxbridge.co.uk/locations/hillingdon/gutter-repairs/" }
];

const faqs = [
  {
    q: "How much do gutter repairs cost in Hillingdon?",
    a: "Gutter repair costs in Hillingdon typically range from £150 to £400, depending on the type and extent of damage. Simple resealing of a leaking joint may cost £150–£200, while bracket replacement or sagging gutter straightening on 1930s-1960s properties in UB10 may reach £350–£400. Emergency same-day repairs attract a £50 premium. We provide a fixed quote after inspection."
  },
  {
    q: "Can you repair cast iron gutters in UB10?",
    a: "Yes. Many mixed 1930s-1960s properties in Hillingdon still have original or replacement cast-iron guttering. We specialise in repairing cast iron gutters by resealing corroded joints, replacing rusted sections, and re-bedding loose brackets. Cast iron repairs often extend gutter life by 5–10 years. We carry stocks of matching cast-iron fittings suitable for UB10 properties."
  },
  {
    q: "My gutter is leaking at the joint in Hillingdon - can you fix it same day?",
    a: "In most cases, yes. Leaking joints are our most common repair, and we can reseal them the same day if you call before 2pm and we have availability. Emergency call-outs for active water leaks damaging interior walls are prioritised. We carry sealants suitable for both cast-iron and uPVC gutters on mixed 1930s-1960s housing in Hillingdon."
  },
  {
    q: "What causes gutters to sag on mixed 1930s to 1960s housing in Hillingdon?",
    a: "Sagging occurs when gutter brackets deteriorate or become loose over 60–90 years. On 1930s-1960s properties, original brackets corrode internally, lose grip on the gutter, and allow the system to sag under its own weight and the load of standing water or debris. Water weight is often the final trigger—blocked gutters in Hillingdon quickly sag once debris accumulates. We reseat and replace weak brackets to restore proper pitch."
  },
  {
    q: "How do I know if my Hillingdon home needs repairs or a full replacement?",
    a: "If your 1930s-1960s Hillingdon property has only 1–2 isolated leaks or loose brackets, repair is usually the best choice. But if you see multiple leaks, extensive rust, widespread sagging, or cracks across the gutter run, replacement may be more cost-effective. We'll advise honestly after inspection—many UB10 properties can be repaired for 3–5 more years of reliable service."
  },
  {
    q: "Do you repair fascia boards as well as gutters in UB10?",
    a: "Yes. We repair and replace fascia boards damaged by years of gutter overflow on mixed 1930s-1960s housing. Soft rot and water stains are common on older Hillingdon properties. We can patch small areas or replace full boards. This work is often paired with gutter repair to stop further water damage."
  },
  {
    q: "Are your gutter repairs guaranteed in Hillingdon?",
    a: "All repair work includes a 12-month parts and labour guarantee. We stand behind every reseal, bracket replacement, and section repair we carry out on Hillingdon UB10 properties. If an issue recurs within the guarantee period, we'll return and fix it at no cost. Guarantee terms are confirmed in writing when we issue your repair quote."
  }
];

const schemas: WithContext<Thing>[] = [
  breadcrumbSchema(breadcrumbItems),
  localBusinessWithAreaSchema("Hillingdon UB10"),
  faqSchema(faqs),
  serviceSchema("Gutter Repairs in Hillingdon UB10", "Fast gutter repairs for leaking joints, sagging sections, and bracket issues on mixed 1930s to 1960s housing.", "https://www.guttercleanersuxbridge.co.uk/locations/hillingdon/gutter-repairs/")
];

const reviews = [
  {
    name: "Sarah H.",
    street: "Ickenham, Hillingdon, UB10",
    date: "May 2026",
    text: "Water was leaking into our bedroom ceiling during rain. They came the same day, found the faulty joint, resealed it, and tested it. Three weeks on and still completely dry. Excellent response time."
  },
  {
    name: "David L.",
    street: "Hillingdon village, UB10",
    date: "April 2026",
    text: "Our 1930s semi had sagging gutters on both sides. They explained the brackets had corroded and showed us the rust. Fixed it same visit, now perfectly level. They even treated it to slow future rust."
  },
  {
    name: "Jennifer T.",
    street: "Station Road, Hillingdon, UB10",
    date: "March 2026",
    text: "Cast iron gutters on our old property needed work. The team knew exactly how to handle them and did a professional job. Didn't try to oversell us on replacement when repair was the right choice."
  }
];
---

<Layout title={title} description={metaDescription} schema={schemas}>

  <!-- Hero -->
  <section class="relative w-full h-96 overflow-hidden">
    <img src="/images/gutter-repairs-hero.jpg" alt="Professional gutter repairs in Hillingdon UB10" class="w-full h-full object-cover" />
    <div class="absolute inset-0 hero-overlay"></div>
    <div class="absolute inset-0 flex items-center justify-center px-4">
      <div class="text-center text-white max-w-3xl mx-auto">
        <div class="flex items-center justify-center gap-2 text-blue-200 text-sm font-semibold uppercase tracking-wide mb-3">
          <MapPin className="w-4 h-4" />
          <span>Hillingdon — UB10</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Gutter Repairs in Hillingdon UB10</h1>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">Fast fixes for leaking joints, sagging gutters, and cracked sections on mixed 1930s to 1960s housing. Same-week response.</p>

        <div class="quick-answer bg-white/10 border border-white/20 rounded-xl p-5 max-w-2xl mx-auto text-left">
          <p class="text-sm font-semibold text-blue-200 uppercase tracking-wide mb-1">Quick Answer</p>
          <p class="text-white text-base leading-relaxed">We repair leaking joints, sagging gutters, cracked sections and loose brackets in Hillingdon UB10. Most repairs take 1 to 2 hours and are completed in a single visit. We aim to respond within 48 hours for urgent issues.</p>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Intro -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-lg text-gray-700 leading-relaxed mb-5">
        Hillingdon's mixed 1930s to 1960s housing stock has now endured 60 to 90 years of exposure to weather, seasonal freeze-thaw cycles, and the weight of accumulated debris from surrounding mature gardens. Gutters built in that era were engineered for durability, but their brackets, joints, and seals begin to fail within 50–70 years. Once failure starts, water leaks accelerate structural damage to fascia boards, soffits, and eventually the eaves and walls beneath.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed mb-5">
        Cast-iron guttering on 1930s Hillingdon properties rusts from the inside out; uPVC systems installed in the 1960s or as replacements develop brittleness and joint separation. Both systems become vulnerable to sagging when brackets weaken, concentrating water weight and creating pools that foster moss growth and further blockage. Repairs made early can extend gutter life significantly and prevent expensive fascia or rafter replacement later.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed">
        We specialise in fast, honest repair assessments for Hillingdon UB10 properties, replacing only what's necessary to restore function and prevent water damage to your 1930s-1960s home.
      </p>
    </div>
  </section>

  <!-- Common Issues -->
  <section class="py-14 bg-blue-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Common Gutter Issues on Hillingdon Homes</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-3 text-lg">Leaking Joints</h3>
          <p class="text-gray-700 mb-3">Occurs when gutter joint sealant deteriorates or brackets loosen. Common on 1930s cast-iron gutters and replacement uPVC systems. Water drips onto fascia boards and walls, staining exterior paintwork and accelerating rot.</p>
          <p class="text-sm text-blue-600 font-semibold">Repair: Reseal or replace joint bracket</p>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-3 text-lg">Sagging Gutters</h3>
          <p class="text-gray-700 mb-3">Brackets corrode or fatigue over decades on 1930s-1960s properties, allowing gutters to sag under their own weight plus debris and water load. Creates pools of standing water that accelerate moss growth and blockage.</p>
          <p class="text-sm text-blue-600 font-semibold">Repair: Replace brackets and re-pitch</p>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-3 text-lg">Cracked Sections</h3>
          <p class="text-gray-700 mb-3">Freeze-thaw cycles in Hillingdon cause cracks to develop in cast iron or brittle uPVC. Cracks may be small (causing slow seeps) or large (causing streaming water damage to exterior walls).</p>
          <p class="text-sm text-blue-600 font-semibold">Repair: Section replacement or epoxy seal</p>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-200">
          <h3 class="font-bold text-gray-900 mb-3 text-lg">Loose or Missing Brackets</h3>
          <p class="text-gray-700 mb-3">Gutter brackets on 1930s-1960s properties corrode internally and lose their grip. Gutters may move, creak, or partially detach from the fascia, especially during wind or under debris load.</p>
          <p class="text-sm text-blue-600 font-semibold">Repair: Bracket replacement and re-fixing</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Repairs -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Repair Options We Offer</h2>

      <div class="space-y-6">
        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-bold text-gray-900 mb-2 text-lg">Resealing Joints</h3>
          <p class="text-gray-700 mb-3">We remove old sealant, clean the joint surfaces, and apply modern flexible sealant rated for 10+ years. Ideal for 1930s cast-iron gutters and uPVC systems that are otherwise sound. Cost-effective and quick—typically completed in under an hour.</p>
          <p class="text-sm text-gray-600 italic">Typical cost: £150–£200 per joint</p>
        </div>

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-bold text-gray-900 mb-2 text-lg">Bracket Replacement</h3>
          <p class="text-gray-700 mb-3">Corroded or fatigued brackets are removed and replaced with new stainless steel or galvanised brackets matched to your gutter profile. We re-pitch the gutter as necessary to restore proper drainage slope. Essential repair on sagging gutters in Hillingdon.</p>
          <p class="text-sm text-gray-600 italic">Typical cost: £200–£350 depending on number of brackets</p>
        </div>

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-bold text-gray-900 mb-2 text-lg">Section Replacement</h3>
          <p class="text-gray-700 mb-3">If a gutter section is cracked or extensively corroded, we remove the damaged section and install a new matching section, re-sealing joints to the surrounding guttering. This approach extends system life while avoiding full replacement cost.</p>
          <p class="text-sm text-gray-600 italic">Typical cost: £250–£400 depending on section length</p>
        </div>

        <div class="border border-gray-200 rounded-xl p-6">
          <h3 class="font-bold text-gray-900 mb-2 text-lg">Epoxy Sealing of Cracks</h3>
          <p class="text-gray-700 mb-3">For small cracks in cast iron, we can apply an epoxy-based repair compound that bonds to the metal and seals the crack. This buys time on older systems and is less invasive than section replacement, but typically lasts 3–5 years before the system requires more extensive work.</p>
          <p class="text-sm text-gray-600 italic">Typical cost: £100–£180</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Repair vs Replace -->
  <section class="py-14 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Repair vs. Replace: What's Right for Your Hillingdon Home?</h2>

      <div class="bg-white rounded-xl p-8 border border-gray-200">
        <div class="space-y-6">
          <div>
            <h3 class="font-bold text-blue-600 mb-3 text-lg">Choose Repair If:</h3>
            <ul class="space-y-2">
              <li class="flex gap-3">
                <span class="text-green-600 font-bold">✓</span>
                <span class="text-gray-700">You have 1–3 isolated leaks or loose brackets</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-600 font-bold">✓</span>
                <span class="text-gray-700">The rest of your 1930s-1960s gutter system is structurally sound</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-600 font-bold">✓</span>
                <span class="text-gray-700">You want to minimise cost and disruption</span>
              </li>
              <li class="flex gap-3">
                <span class="text-green-600 font-bold">✓</span>
                <span class="text-gray-700">You plan to stay in the property 5+ more years</span>
              </li>
            </ul>
          </div>

          <hr class="my-6" />

          <div>
            <h3 class="font-bold text-red-600 mb-3 text-lg">Choose Replacement If:</h3>
            <ul class="space-y-2">
              <li class="flex gap-3">
                <span class="text-red-600 font-bold">✗</span>
                <span class="text-gray-700">Multiple leaks across different sections or joints</span>
              </li>
              <li class="flex gap-3">
                <span class="text-red-600 font-bold">✗</span>
                <span class="text-gray-700">Extensive rust or corrosion on cast-iron gutters</span>
              </li>
              <li class="flex gap-3">
                <span class="text-red-600 font-bold">✗</span>
                <span class="text-gray-700">Sagging across a long gutter run (more than 50% of system)</span>
              </li>
              <li class="flex gap-3">
                <span class="text-red-600 font-bold">✗</span>
                <span class="text-gray-700">Repeated repairs required within 12 months</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="mt-8 bg-blue-50 rounded-lg p-5 border border-blue-200">
          <p class="text-gray-700"><strong>We'll advise honestly:</strong> After inspecting your Hillingdon UB10 property, we'll recommend the most cost-effective solution. We only replace gutters when repair is no longer viable, saving you money wherever possible.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Our Repair Process</h2>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
          <div class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold mb-4">1</div>
          <h3 class="font-bold text-gray-900 mb-3">Inspection</h3>
          <p class="text-gray-700 text-sm">We assess your Hillingdon gutters, identify the damage, and determine whether repair or replacement is appropriate.</p>
        </div>

        <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
          <div class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold mb-4">2</div>
          <h3 class="font-bold text-gray-900 mb-3">Quote & Approval</h3>
          <p class="text-gray-700 text-sm">We provide a fixed price, explain the work, and confirm your approval before starting any repairs.</p>
        </div>

        <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
          <div class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold mb-4">3</div>
          <h3 class="font-bold text-gray-900 mb-3">Repair Work</h3>
          <p class="text-gray-700 text-sm">We carry out the repair work using quality materials suited to 1930s-1960s housing. Most jobs take 1–2 hours.</p>
        </div>

        <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
          <div class="w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold mb-4">4</div>
          <h3 class="font-bold text-gray-900 mb-3">Testing & Guarantee</h3>
          <p class="text-gray-700 text-sm">We test the repaired section with water, provide written confirmation, and guarantee the work for 12 months.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-14 bg-blue-50">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-3 text-center">Other Services in Hillingdon</h2>
      <p class="text-gray-600 text-center mb-10">If repairs aren't the right solution, we also offer cleaning and full replacement for UB10 properties.</p>

      <div class="grid md:grid-cols-3 gap-6">
        <a href="/locations/hillingdon/gutter-cleaning/" class="group bg-white border border-gray-200 hover:border-blue-500 rounded-xl p-6 transition-all hover:shadow-md">
          <h3 class="text-lg font-bold text-blue-900 mb-2 group-hover:text-blue-600">Gutter Cleaning</h3>
          <p class="text-gray-600 text-sm mb-3">Vacuum-powered debris and moss removal to prevent blockages on mixed 1930s-1960s housing in Hillingdon.</p>
          <span class="inline-flex items-center gap-1 text-blue-600 text-sm font-medium">View service <ArrowRight className="w-4 h-4" /></span>
        </a>

        <a href="/locations/hillingdon/gutter-replacement/" class="group bg-white border border-gray-200 hover:border-blue-500 rounded-xl p-6 transition-all hover:shadow-md">
          <h3 class="text-lg font-bold text-blue-900 mb-2 group-hover:text-blue-600">Gutter Replacement</h3>
          <p class="text-gray-600 text-sm mb-3">Full gutter replacement in uPVC, cast iron, or aluminium for Hillingdon properties beyond repair.</p>
          <span class="inline-flex items-center gap-1 text-blue-600 text-sm font-medium">View service <ArrowRight className="w-4 h-4" /></span>
        </a>

        <a href="/locations/hillingdon/fascia-soffit-cleaning/" class="group bg-white border border-gray-200 hover:border-blue-500 rounded-xl p-6 transition-all hover:shadow-md">
          <h3 class="text-lg font-bold text-blue-900 mb-2 group-hover:text-blue-600">Fascia & Soffit Cleaning</h3>
          <p class="text-gray-600 text-sm mb-3">Clean and restore fascia boards damaged by years of gutter overflow on UB10 homes.</p>
          <span class="inline-flex items-center gap-1 text-blue-600 text-sm font-medium">View service <ArrowRight className="w-4 h-4" /></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-10 text-center">Hillingdon Customer Reviews</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="flex gap-0.5 mb-3">
              {[1,2,3,4,5].map(() => (
                <span class="text-yellow-400 text-lg">★</span>
              ))}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed mb-4 italic">"{r.text}"</p>
            <p class="font-semibold text-gray-900 text-sm">{r.name}</p>
            <p class="text-gray-500 text-xs">{r.street} • {r.date}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quote Form -->
  <section class="py-14 bg-blue-50">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-3 text-center">Free Repair Quote for Your Hillingdon Property</h2>
      <p class="text-gray-600 text-center mb-10">Describe the issue you've noticed and submit your address. We'll contact you within 24 hours to arrange an inspection and provide a fixed price.</p>
      <QuoteForm client:load />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-10 text-center">Gutter Repair FAQs for Hillingdon</h2>
      <div class="space-y-5">
        {faqs.map((item) => (
          <details class="group border border-gray-200 rounded-xl p-6">
            <summary class="font-bold text-gray-900 cursor-pointer flex justify-between items-center">
              {item.q}
              <span class="text-blue-600 group-open:rotate-180 transition-transform">+</span>
            </summary>
            <p class="text-gray-700 leading-relaxed text-sm mt-4">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Locations -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gray-600 text-sm mb-3">Gutter repairs also available in:</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/locations/uxbridge/" class="text-blue-600 hover:underline text-sm">Uxbridge</a>
        <a href="/locations/harrow/" class="text-blue-600 hover:underline text-sm">Harrow</a>
        <a href="/locations/hayes/" class="text-blue-600 hover:underline text-sm">Hayes</a>
        <a href="/locations/" class="text-blue-600 hover:underline text-sm">All locations →</a>
      </div>
    </div>
  </section>

</Layout>
