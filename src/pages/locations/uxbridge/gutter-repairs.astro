              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 text-lg">✓</span>
                <span>Most repairs 1–2 hours</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 text-lg">✓</span>
                <span>12-month guarantee</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue-600 text-lg">✓</span>
                <span>Free inspection</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust Bar -->
    <TrustBar />
