---
import Layout from "@/layouts/Layout.astro";
import QuoteForm from "@/components/QuoteForm";
import { getCollection, render } from "astro:content";
import type { WithContext, BlogPosting } from "schema-dts";
import { blogPostSchema } from "@/lib/schema";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Related posts — other posts excluding current
const allPosts = await getCollection("blog");
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
}

const categoryColours: Record<string, string> = {
  "Tips & Advice": "bg-blue-100 text-blue-800",
  "Local Guides": "bg-green-100 text-green-800",
  "Pricing": "bg-orange-100 text-orange-800",
};

const schema: WithContext<BlogPosting> = blogPostSchema(
  post.data.title,
  post.data.description,
  Astro.url.href,
  post.data.pubDate.toISOString(),
  `https://www.guttercleanersuxbridge.co.uk${post.data.heroImage}`
);
---

<Layout
  title={post.data.title}
  description={post.data.description}
  schema={schema}
  socialImageUrl={`https://www.guttercleanersuxbridge.co.uk${post.data.heroImage}`}
>
  <!-- Post Hero -->
  <section class="relative w-full h-80 md:h-96 overflow-hidden">
    <img
      src={post.data.heroImage}
      alt={post.data.title}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 hero-overlay"></div>
    <div class="absolute inset-0 flex items-end justify-start px-4 pb-10">
      <div class="max-w-3xl">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4 ${categoryColours[post.data.category] || "bg-gray-100 text-gray-700"}`}>
          {post.data.category}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
          {post.data.title}
        </h1>
      </div>
    </div>
  </section>

  <!-- Article Body + Sidebar -->
  <section class="section bg-surface">
    <div class="container-site">
      <div class="grid lg:grid-cols-[1fr_340px] gap-12 items-start">

        <!-- Main Article Content -->
        <article>
          <!-- Meta -->
          <div class="flex flex-wrap items-center gap-4 mb-8 pb-6 border-b border-border">
            <div class="flex items-center gap-2 text-sm text-text-muted">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <time datetime={post.data.pubDate.toISOString()}>
                Published {formatDate(post.data.pubDate)}
              </time>
            </div>
            {post.data.updatedDate && (
              <div class="flex items-center gap-2 text-sm text-text-muted">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                </svg>
                <time datetime={post.data.updatedDate.toISOString()}>
                  Updated {formatDate(post.data.updatedDate)}
                </time>
              </div>
            )}
            <div class="flex items-center gap-2 text-sm text-text-muted">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span>Gutter Cleaners Uxbridge Team</span>
            </div>
          </div>

          <!-- MDX Content -->
          <div class="prose prose-lg prose-blue max-w-none
            prose-headings:font-bold prose-headings:text-text
            prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-text-muted prose-p:leading-relaxed
            prose-a:text-brand prose-a:font-semibold prose-a:no-underline hover:prose-a:underline
            prose-strong:text-text
            prose-ul:text-text-muted prose-ol:text-text-muted
            prose-li:my-1
            prose-table:text-sm
            prose-th:bg-brand prose-th:text-white prose-th:font-semibold prose-th:px-4 prose-th:py-2
            prose-td:px-4 prose-td:py-2 prose-td:border prose-td:border-border
            prose-hr:border-border
            prose-blockquote:border-l-brand prose-blockquote:text-text-muted
          ">
            <Content />
          </div>

          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <div class="mt-10 pt-6 border-t border-border">
              <p class="text-sm font-semibold text-text mb-3">Tags:</p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-3 py-1 bg-blue-50 text-brand text-xs font-medium rounded-full border border-blue-100">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Related Posts -->
          {relatedPosts.length > 0 && (
            <div class="mt-12 pt-8 border-t border-border">
              <h2 class="text-2xl font-bold text-text mb-6">Related Articles</h2>
              <div class="grid sm:grid-cols-2 gap-6">
                {relatedPosts.map((related) => (
                  <a
                    href={`/blog/${related.id}/`}
                    class="group block bg-blue-50 rounded-xl p-5 border border-blue-100 hover:border-brand hover:shadow-md transition-all"
                  >
                    <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-semibold mb-2 ${categoryColours[related.data.category] || "bg-gray-100 text-gray-700"}`}>
                      {related.data.category}
                    </span>
                    <h3 class="font-bold text-text text-base leading-snug group-hover:text-brand transition-colors mb-2">
                      {related.data.title}
                    </h3>
                    <p class="text-text-muted text-sm line-clamp-2">
                      {related.data.description}
                    </p>
                    <span class="mt-3 inline-flex items-center gap-1 text-brand text-sm font-semibold">
                      Read more
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7"></path>
                      </svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </article>

        <!-- Sidebar -->
        <aside class="space-y-8 lg:sticky lg:top-8">
          <!-- Quote Form Card -->
          <div class="bg-brand rounded-2xl p-6 text-white">
            <h3 class="text-xl font-bold mb-2">Get a Free Quote</h3>
            <p class="text-blue-100 text-sm mb-6">
              Professional gutter cleaning across West London. We respond within 2 hours.
            </p>
            <div class="bg-white rounded-xl p-4">
              <QuoteForm client:load />
            </div>
          </div>

          <!-- About Us Card -->
          <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
            <h3 class="text-lg font-bold text-text mb-3">About Us</h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              Gutter Cleaners Uxbridge provides professional gutter cleaning, repair, and replacement
              across Uxbridge, Harrow, Hayes, Hillingdon, Slough, Southall, West Drayton and Windsor.
            </p>
            <ul class="space-y-2 text-sm text-text-muted">
              <li class="flex items-center gap-2">
                <span class="text-brand font-bold">✓</span>
                Fully insured (£6m public liability)
              </li>
              <li class="flex items-center gap-2">
                <span class="text-brand font-bold">✓</span>
                Vacuum-powered — zero mess
              </li>
              <li class="flex items-center gap-2">
                <span class="text-brand font-bold">✓</span>
                Before & after photos provided
              </li>
              <li class="flex items-center gap-2">
                <span class="text-brand font-bold">✓</span>
                Same-week appointments available
              </li>
            </ul>
          </div>

          <!-- Services Links -->
          <div class="bg-white rounded-2xl p-6 border border-border">
            <h3 class="text-lg font-bold text-text mb-4">Our Services</h3>
            <nav class="space-y-2">
              <a
                href="/services/gutter-cleaning/"
                class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-blue-50 hover:text-brand transition-colors text-text-muted text-sm font-medium"
              >
                Gutter Cleaning
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>
              <a
                href="/services/gutter-repairs/"
                class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-blue-50 hover:text-brand transition-colors text-text-muted text-sm font-medium"
              >
                Gutter Repairs
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>
              <a
                href="/services/gutter-replacement/"
                class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-blue-50 hover:text-brand transition-colors text-text-muted text-sm font-medium"
              >
                Gutter Replacement
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>
              <a
                href="/services/fascia-soffit-cleaning/"
                class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-blue-50 hover:text-brand transition-colors text-text-muted text-sm font-medium"
              >
                Fascia & Soffit
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </a>
            </nav>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
